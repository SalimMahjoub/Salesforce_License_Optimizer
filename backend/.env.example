# =============================================================================
# Backend Environment Template (used when running backend OUTSIDE docker)
# =============================================================================
# Copy to backend/.env for local `uvicorn` runs.
# Inside docker-compose, values come from the root .env (see ../.env.example).
# -----------------------------------------------------------------------------

APP_NAME=salesforce-license-optimizer
# "demo" (default) = in-memory 800-user generator. "salesforce" = live OAuth.
DATA_PROVIDER=demo
APP_ENV=development
DEBUG=true
LOG_LEVEL=INFO

# Database (local Postgres)
DATABASE_URL=postgresql+asyncpg://slo_user:slo_password@localhost:5432/license_optimizer
DATABASE_POOL_SIZE=10

# Redis
REDIS_URL=redis://localhost:6379/0

# Salesforce
SF_CLIENT_ID=your_connected_app_client_id
SF_CLIENT_SECRET=your_connected_app_client_secret
SF_REDIRECT_URI=http://localhost:8000/oauth/callback

# OpenAI
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=gpt-4

# Security
# python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=change_me_minimum_32_chars
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=change_me_fernet_44_chars_base64
CORS_ORIGINS=["http://localhost:3000"]
