# =============================================================================
# Salesforce License Optimizer - Environment Template (ROOT)
# =============================================================================
# Copy this file to `.env` and fill in your own values.
# This root .env is consumed by docker-compose.yml via ${VAR} interpolation.
# NEVER commit the .env file. All secrets below are required in production.
# -----------------------------------------------------------------------------

# --- Salesforce Connected App ---
# Create one at: Setup > App Manager > New Connected App
SF_CLIENT_ID=your_connected_app_client_id
SF_CLIENT_SECRET=your_connected_app_client_secret
SF_REDIRECT_URI=http://localhost:8000/oauth/callback

# --- OpenAI (GPT-4) ---
OPENAI_API_KEY=sk-your-openai-api-key

# --- JWT / Encryption ---
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=change_me_minimum_32_chars_use_secrets_token_urlsafe_48
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=change_me_fernet_44_chars_base64

# --- Notifications (optional) ---
SLACK_WEBHOOK_URL=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# --- Frontend build (Vite) ---
VITE_API_URL=http://localhost:8000

# --- Data source ---
# "demo" (default) generates 800 fake users — no Salesforce required.
# "salesforce" pulls live data via OAuth (requires SF_CLIENT_*).
DATA_PROVIDER=demo
